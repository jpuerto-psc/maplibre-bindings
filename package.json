{
  "name": "maplibre-bindings",
  "version": "0.2.5",
  "description": "...",
  "main": "index.js",
  "directories": {
    "example": "examples",
    "test": "tests"
  },
  "scripts": {
    "build-py": "esbuild src/index-py.js --bundle --minify --outfile=py-bindings/pymaplibre.js",
    "build-py-dev": "esbuild src/index-py.js --bundle --outfile=py-bindings/pymaplibre.js",
    "build-ipywidget": "esbuild src/ipywidget.js --bundle --minify --format=esm --outfile=py-bindings/pymaplibre.ipywidget.js",
    "build-ipywidget-dev": "esbuild src/ipywidget.js --bundle --format=esm --outfile=py-bindings/pymaplibre.ipywidget.js",
    "build-r": "esbuild src/index-r.js --bundle --minify --outfile=r-bindings/rmaplibre.js",
    "build-r-dev": "esbuild src/index-r.js --bundle --outfile=r-bindings/rmaplibre.js",
    "build-py-dev-ts": "tsc --build && cp -r src-ts/css built && esbuild built/index-py.js --bundle --outfile=py-bindings/pymaplibre-dev-ts.js",
    "build-py-ts": "tsc --build && cp -r src-ts/css built && esbuild built/index-py.js --bundle --minify --outfile=py-bindings/pymaplibre.js",
    "prettier": "prettier src --write",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build-ipywidget-ts": "tsc --build && cp -r src-ts/css built && esbuild built/anywidget/ipywidget.js --bundle --minify --outfile=py-bindings/pymaplibre.ipywidget.js"
  },
  "author": "Stefan Kuethe",
  "license": "MIT",
  "devDependencies": {
    "@anywidget/types": "^0.2.0",
    "@types/mapbox__mapbox-gl-draw": "^1.4.8",
    "@types/mustache": "^4.2.5",
    "esbuild": "0.19.10",
    "prettier": "3.1.1",
    "typescript": "^5.7.3",
    "typescript-plugin-css-modules": "^5.1.0"
  },
  "dependencies": {
    "@deck.gl/aggregation-layers": "^9.1.0",
    "@deck.gl/geo-layers": "^9.1.0",
    "@deck.gl/json": "^9.1.0",
    "@deck.gl/layers": "^9.1.0",
    "@deck.gl/mapbox": "^9.1.0",
    "@mapbox/mapbox-gl-draw": "^1.5.0",
    "@maplibre/maplibre-gl-geocoder": "^1.8.0",
    "@maptiler/geocoding-control": "^2.1.6",
    "maplibre-gl": "^5.3.1",
    "mustache": "^4.2.0",
    "pmtiles": "^3.2.1"
  }
}